# Test Environment Configuration
# Copy this file to .env.test and customize for your test environment

# Server
DRAMA_SERVER_PORT=9000

# Crawl schedule (Asia/Shanghai timezone)
DRAMA_CRAWL_HOUR=0
DRAMA_CRAWL_MINUTE=0

# Timezone
DRAMA_TIMEZONE=Asia/Shanghai

# HTTP settings - more conservative for test env
DRAMA_HTTP_TIMEOUT=30.0
DRAMA_HTTP_DELAY_SECONDS=0.5
DRAMA_HTTP_MAX_RETRIES=3

# User-Agent
DRAMA_USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/135.0.0.0 Safari/537.36

# Debug mode - limit items for testing
DRAMA_MAX_ITEMS=100

# Site URLs (default values)
NETSHORT_ALL_PLOTS_URL=https://netshort.com/drama/all-plots
NETSHORT_HOME_URL=https://netshort.com/
DRAMABOX_BASE_URL=https://www.dramabox.com
REELSHORT_ALL_MOVIES_URL=https://www.reelshort.com/movie-genres/all-movies
SHORTMAX_DRAMAS_URL=https://www.shorttv.live/dramas
