# ===========================================
# Drama Web Crawler 配置文件
# ===========================================
# 使用方法：
#   1. 复制此文件为 .env
#   2. 根据需要修改配置项
#   3. 运行 uv run python main.py 启动服务
# ===========================================

# -------------------------------------------
# 服务器配置
# -------------------------------------------
# API 服务监听端口
DRAMA_SERVER_PORT=9000

# -------------------------------------------
# 定时爬取配置
# -------------------------------------------
# 爬取任务执行时间（24 小时制）
# 默认每天 00:00 执行
DRAMA_CRAWL_HOUR=0
DRAMA_CRAWL_MINUTE=0

# -------------------------------------------
# 基础配置
# -------------------------------------------
# 时区
DRAMA_TIMEZONE=Asia/Shanghai

# 数据目录（可选，默认项目根目录/data）
# DRAMA_DATA_DIR=/path/to/data

# 导出目录（可选，默认 DATA_DIR/exports）
# DRAMA_EXPORTS_DIR=/path/to/exports

# 日志目录（可选，默认项目根目录/logs）
# DRAMA_LOGS_DIR=/path/to/logs

# -------------------------------------------
# HTTP 配置
# -------------------------------------------
# HTTP 请求超时时间（秒）
DRAMA_HTTP_TIMEOUT=20.0

# HTTP 请求间隔（秒），用于限流
DRAMA_HTTP_DELAY_SECONDS=0.0

# HTTP 请求最大重试次数
DRAMA_HTTP_MAX_RETRIES=2

# User-Agent
DRAMA_USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/135.0.0.0 Safari/537.36

# -------------------------------------------
# 调试配置
# -------------------------------------------
# 最大抓取记录数（可选，用于调试，不限制则留空）
# DRAMA_MAX_ITEMS=10

# -------------------------------------------
# 站点配置
# -------------------------------------------
# NetShort
NETSHORT_ALL_PLOTS_URL=https://netshort.com/drama/all-plots
NETSHORT_HOME_URL=https://netshort.com/

# DramaBox
DRAMABOX_BASE_URL=https://www.dramabox.com

# ReelShort
REELSHORT_ALL_MOVIES_URL=https://www.reelshort.com/movie-genres/all-movies

# ShortMax
SHORTMAX_DRAMAS_URL=https://www.shorttv.live/dramas
